AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
EMBED_MODEL_NAME=all-MiniLM-L6-v2

# --- Generation provider ---
# "bedrock" (default) or "anthropic_direct" to bypass Bedrock quota approval
GENERATION_PROVIDER=bedrock

# Used when GENERATION_PROVIDER=bedrock:
GEN_MODEL_ID=us.anthropic.claude-<current-inference-profile-id>
# Fallback while waiting on Claude quota approval — different request/response
# shape, already handled in rag.py's _generate():
# GEN_MODEL_ID=ai21.jamba-1-5-large-v1:0

# Used when GENERATION_PROVIDER=anthropic_direct (get a key from console.anthropic.com):
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-5
